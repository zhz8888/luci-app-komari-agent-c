# Base image for amd64, arm64, armhf, riscv64, i386 cross-compilation.
# Ubuntu 24.04 (noble) ports repo provides libc6-dev-*-cross and target
# libraries for these architectures. For armel/mipsel/mips64el use the
# companion Dockerfile.legacy (debian:bookworm-slim) instead, because
# Ubuntu 24.04 lacks cross support for those targets.
#
# BASE_IMAGE is parameterized so CI can pin a digest-locked image for
# reproducible builds (see docker/README.md → "Pinning base image digests"):
#   docker build --build-arg BASE_IMAGE=ubuntu:24.04@sha256:<hash> ...
# The default (ubuntu:24.04) uses the mutable tag for local development.
ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

ARG DEBIAN_ARCH=amd64
ARG MULTIARCH_TRIPLET=x86_64-linux-gnu
ARG CC_PKG=gcc
ARG CC=gcc
# APT_MIRROR: "default" for official Ubuntu mirrors (CI), "cn" for Tsinghua mirror (local builds in China)
ARG APT_MIRROR=default

ENV DEBIAN_FRONTEND=noninteractive
ENV DEBIAN_ARCH=${DEBIAN_ARCH}
ENV MULTIARCH_TRIPLET=${MULTIARCH_TRIPLET}
ENV CC=${CC}

# Install ca-certificates first so HTTPS works for ports.ubuntu.com if needed
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Configure apt sources for cross-compilation
# Ubuntu 24.04 uses DEB822 format at /etc/apt/sources.list.d/ubuntu.sources
# - Optionally switch to Tsinghua mirror (cn)
# - For non-amd64: add Architectures: amd64 restriction to main sources,
#   dpkg --add-architecture, and add ports repository for target libraries
# - i386 uses main repository (not ports); other foreign archs use ports
RUN if [ "$APT_MIRROR" = "cn" ]; then \
      sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.tuna.tsinghua.edu.cn/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources && \
      sed -i 's|http://security.ubuntu.com/ubuntu/|http://mirrors.tuna.tsinghua.edu.cn/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources; \
    fi && \
    if [ "$DEBIAN_ARCH" != "amd64" ]; then \
      if [ "$DEBIAN_ARCH" = "i386" ]; then \
        sed -i '/^Signed-By:/a Architectures: amd64 i386' /etc/apt/sources.list.d/ubuntu.sources && \
        dpkg --add-architecture "$DEBIAN_ARCH"; \
      else \
        sed -i '/^Signed-By:/a Architectures: amd64' /etc/apt/sources.list.d/ubuntu.sources && \
        dpkg --add-architecture "$DEBIAN_ARCH" && \
        if [ "$APT_MIRROR" = "cn" ]; then \
          PORTS_URI="http://mirrors.tuna.tsinghua.edu.cn/ubuntu-ports/"; \
        else \
          PORTS_URI="http://ports.ubuntu.com/ubuntu-ports/"; \
        fi && \
        printf 'Types: deb\nURIs: %s\nSuites: noble noble-updates noble-backports\nComponents: main universe restricted multiverse\nArchitectures: %s\nSigned-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg\n\nTypes: deb\nURIs: %s\nSuites: noble-security\nComponents: main universe restricted multiverse\nArchitectures: %s\nSigned-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg\n' "$PORTS_URI" "$DEBIAN_ARCH" "$PORTS_URI" "$DEBIAN_ARCH" > /etc/apt/sources.list.d/ports.sources; \
      fi; \
    fi

# Install build tools, cross-compiler, and target architecture libraries
RUN apt-get update && \
    if [ "$DEBIAN_ARCH" != "amd64" ]; then \
      apt-get install -y --no-install-recommends \
        cmake make pkg-config file ca-certificates \
        "$CC_PKG" \
        "libssl-dev:$DEBIAN_ARCH" \
        "zlib1g-dev:$DEBIAN_ARCH"; \
    else \
      apt-get install -y --no-install-recommends \
        cmake make pkg-config file ca-certificates \
        "$CC_PKG" libssl-dev zlib1g-dev; \
    fi && \
    rm -rf /var/lib/apt/lists/*

COPY docker/build.sh /usr/local/bin/build.sh
COPY docker/test.sh /usr/local/bin/test.sh
RUN chmod +x /usr/local/bin/build.sh /usr/local/bin/test.sh

WORKDIR /src
