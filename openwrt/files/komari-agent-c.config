config komari-agent-c 'komari-agent-c'
	option token ''
	option endpoint ''
	option interval '1.0'
	option custom_dns ''
	option ignore_unsafe_cert '0'
	option disable_web_ssh '0'
	option max_retries '5'
	option reconnect_interval '5'
	option info_report_interval '30'
	option month_rotate '0'
	option include_nics ''
	option exclude_nics ''
	option include_mountpoints ''
	option custom_ipv4 ''
	option custom_ipv6 ''
	# GPU monitoring (true/false, default false)
	option enable_gpu '0'
	option language 'auto'
	# Auto-discovery key (optional, used for auto-registration to the panel)
	option auto_discovery_key ''
	# Protocol version (1 or 2, default 2)
	option protocol_version '2'
	# Disable compression (true/false, default false)
	option disable_compression '0'
	# Disable auto-update check (true/false, default false)
	option disable_auto_update '0'
